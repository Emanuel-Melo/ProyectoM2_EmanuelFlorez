{
  "name": "miniblog-api",
  "version": "1.0.0",
  "description": "REST API for managing authors, posts and comments using Node.js, Express and PostgreSQL",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "jest --watch"
  },
  "jest": {
    "testEnvironment": "node",
    "testRegex": "tests/.*\\.js$",
    "transform": {},
    "setupFilesAfterEnv": ["<rootDir>/tests/setup.js"]
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}